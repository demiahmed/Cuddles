# ─────────────────────────────────────────────────────────────────────────────
# Cuddles — Environment Configuration
# Copy this file to .env and fill in your values before starting the app.
# ─────────────────────────────────────────────────────────────────────────────

# ── VAPID Keys (required for push notifications) ─────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=you@example.com

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string

# ── Timezone ─────────────────────────────────────────────────────────────────
# Used for scheduling notifications and backup timestamps.
# Any tz database name works: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Asia/Singapore

# ── Notification schedule ─────────────────────────────────────────────────────
# Comma-separated HH:MM times in 24-hour format (your local TZ above).
# Four slots map to: morning period/ovulation, lunch health tips,
# evening intimacy, bedtime wellness reminder / achievement.
NOTIFICATION_TIMES=09:00,13:00,18:30,21:30

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite at /app/instance/menses.db (inside the container).
# Override only if you want a custom path or a different DB.
# DATABASE_URL=sqlite:////app/instance/menses.db

# ── Backups (production only) ─────────────────────────────────────────────────
# How many days of daily SQLite backups to retain in ./instance/backups/
BACKUP_RETENTION_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
# Restrict API access to your domain in production.
# CORS_ORIGIN=https://yourdomain.com
