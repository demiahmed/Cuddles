# Flask Configuration
FLASK_ENV=development

# CORS Configuration
# Set this to your frontend URL in production
CORS_ORIGIN=http://localhost:3000

# Push Notification Configuration (VAPID Keys)
# Generate new VAPID keys for your deployment using:
# python -c "from pywebpush import webpush; print(webpush.generate_vapid())"
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:your-email@example.com

# UI Password Protection (optional)
# Set a password to protect the UI in production
UI_PASSWORD=your-secret-password

# Notification Schedule Configuration
# Hour (0-23) and minute (0-59) for daily notifications
NOTIFICATION_HOUR=11
NOTIFICATION_MINUTE=0

# Timezone Configuration
# Set your local timezone (e.g., Asia/Singapore, America/New_York, Europe/London)
TZ=Asia/Singapore

# Database Configuration (optional overrides)
# By default, the app uses SQLite. Uncomment and configure for other databases:
# DATABASE_URL=postgresql://username:password@localhost/dbname
# DATABASE_URL=mysql://username:password@localhost/dbname

# Security Configuration (recommended for production)
# SECRET_KEY=your-secret-key-for-sessions
# FLASK_SECRET_KEY=your-flask-secret-key

# Logging Configuration (optional)
# LOG_LEVEL=INFO
# LOG_FILE=app.log

# Development Configuration (optional)
# DEBUG=True
# TESTING=False